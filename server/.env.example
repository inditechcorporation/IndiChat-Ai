# Server
PORT=3000
WS_PORT=8765
HOST=192.168.1.100
JWT_SECRET=change_this_to_random_secret_string

# Database
DB_PATH=./data/db.sqlite

# WebSocket URL (what firmware connects to)
WS_URL=ws://192.168.1.100:8765

# Timezone offset in minutes (IST = 330, UTC = 0)
TIMEZONE_OFFSET=330

# ── ADMIN API KEYS (set by admin, users don't need their own) ─────────

# Groq - used for:
#   1. STT (Whisper speech-to-text)
#   2. Default LLM (Llama3, Mixtral - free for users)
#   3. TTS (PlayAI voices)
# Get key: console.groq.com (free)
GROQ_API_KEY=

# TTS Provider: groq | edge | google | openai | elevenlabs
# groq = PlayAI voices (recommended, uses GROQ_API_KEY)
# edge = Microsoft Edge TTS (free, no key needed)
TTS_PROVIDER=groq

# Google Cloud TTS (optional, better quality)
GOOGLE_TTS_API_KEY=

# ElevenLabs TTS (optional, most natural voice)
ELEVENLABS_API_KEY=

# OpenAI (optional fallback for STT/TTS)
OPENAI_API_KEY=
